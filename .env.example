# App
APP_NAME=korede-short-api
APP_ENV=production
APP_PORT=2000
API_KEY=your-api-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://media:password@db:5432/media_master

# Redis
REDIS_URL=redis://redis:6379/0

# Kie.ai
KIE_AI_API_KEY=your-kie-ai-key
KIE_AI_BASE_URL=https://api.kie.ai/api/v1
KIE_AI_CONCURRENCY=5

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_CONCURRENCY=5

# AWS S3
S3_BUCKET=your-media-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Pipeline
BATCH_SIZE=10
MAX_RETRIES=3
SCENE_FAILURE_THRESHOLD=0.5
TEMP_DIR=/tmp/media-master

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
